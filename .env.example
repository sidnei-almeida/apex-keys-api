# PostgreSQL
# Local / Neon: DATABASE_URL
# Railway (API): referencia ao Postgres — DATABASE_URL ou DATABASE_PRIVATE_URL (a app tenta ambos; em Railway prioriza PRIVATE)
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require
# Opcional: retentativas no arranque (Railway quando o Postgres ainda não aceita ligações)
# DB_CONNECT_RETRIES=15
# DB_CONNECT_RETRY_DELAY_SEC=1.0
# DB_CONNECT_RETRY_DELAY_MAX_SEC=8.0
# Railway/local com erro de certificado SSL: lê-se do .env via Settings (bool: 1, true, yes)
DATABASE_SSL_NO_VERIFY=false

# JWT
JWT_SECRET=altere-para-um-segredo-longo-e-aleatorio
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS: lista separada por vírgulas (barra final é removida automaticamente)
CORS_ORIGINS=https://seu-frontend.com,http://localhost:3000

# IGDB scrape: atraso antes do pedido e retries (reduz falhas com Cloudflare)
# IGDB_INITIAL_DELAY_SEC=5
# IGDB_MAX_RETRIES=2
