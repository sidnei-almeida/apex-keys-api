# PostgreSQL (Railway: use a URL pública "TCP Proxy" no dev local; no deploy, variável do painel)
# Ex.: ...proxy.rlwy.net:PORT/railway?sslmode=require
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require
# Railway/local com erro de certificado SSL: lê-se do .env via Settings (bool: 1, true, yes)
DATABASE_SSL_NO_VERIFY=false

# JWT
JWT_SECRET=altere-para-um-segredo-longo-e-aleatorio
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS: lista separada por vírgulas (sem espaços extras)
CORS_ORIGINS=https://seu-frontend.com,http://localhost:3000
