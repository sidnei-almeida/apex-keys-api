# PostgreSQL
# Local / Neon: DATABASE_URL
# Railway (API): referencia ao Postgres — DATABASE_URL ou DATABASE_PRIVATE_URL (a app tenta ambos; em Railway prioriza PRIVATE)
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require
# Opcional: retentativas no arranque (Railway quando o Postgres ainda não aceita ligações)
# DB_CONNECT_RETRIES=15
# DB_CONNECT_RETRY_DELAY_SEC=1.0
# DB_CONNECT_RETRY_DELAY_MAX_SEC=8.0
# Railway/local com erro de certificado SSL: lê-se do .env via Settings (bool: 1, true, yes)
DATABASE_SSL_NO_VERIFY=false

# JWT
JWT_SECRET=altere-para-um-segredo-longo-e-aleatorio
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS: lista separada por vírgulas (barra final removida). Use * para permitir qualquer origem.
CORS_ORIGINS=https://apex-keys-website.vercel.app,http://localhost:3000

# IGDB scrape: atraso antes do pedido e retries (reduz falhas com Cloudflare)
# IGDB_INITIAL_DELAY_SEC=5
# IGDB_MAX_RETRIES=2

# Email (Resend) — notificações de rifa cancelada
# Se omitido, emails não são enviados (apenas notificações in-app)
# RESEND_API_KEY=re_xxx
# EMAIL_FROM=noreply@seudominio.com
# FRONTEND_URL=https://apexkeys.com

# Mercado Pago — com token definido, POST /wallet/mock-pix-intent cria cobrança Pix real e
# POST|GET /webhook/mercadopago recebe notificações. Aceita também o nome com typo MERCADO_PAGO_ACESS_TOKEN.
# MERCADO_PAGO_ACCESS_TOKEN=TEST-...
# No painel MP, configure a URL de notificação: https://<sua-api>/webhook/mercadopago

# UploadThing — avatar do utilizador (se definido, o backend envia o WebP otimizado ≤ 50KB para o UploadThing).
# Formato: token base64 gerado no dashboard (v7). Se omitido, cai no storage local em /uploads/avatars.
# UPLOADTHING_TOKEN=eyJhcGlLZXkiOiJza19saXZlXy4uLiIsImFwcElkIjoiLi4uIiwicmVnaW9ucyI6WyJzZWExIl19

# UploadThing legacy (v6) — alternativa simples para usar a REST v6 diretamente.
# Se definido, tem prioridade sobre UPLOADTHING_TOKEN.
# UPLOADTHING_SECRET=sk_live_...
# UPLOADTHING_APP_ID=xxxx (opcional; não é necessário para o upload REST que usamos)
